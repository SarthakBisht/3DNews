# NewsAPI.org — https://newsapi.org/register
# Free tier works from localhost only; paid from $449/mo.
VITE_NEWSAPI_KEY=

# Currents API — https://currentsapi.services (600 req/day, browser-safe)
# Primary provider; recommended replacement for NewsAPI on free tier.
VITE_CURRENTS_API_KEY=

# NewsData.io — https://newsdata.io (200 req/day, browser-safe)
# Secondary provider; results merged and deduped with other active providers.
VITE_NEWSDATA_KEY=

# GNews — https://gnews.io (100 req/day, dev use only)
# Tertiary provider; browser CORS allowed.
VITE_GNEWS_KEY=
